# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:64321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Migrations CI/CD (production) — nécessaires pour `npm run migrate`
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_ID=

# Inscription (URL secrète)
SIGNUP_SECRET_TOKEN=

# Import de contenu (optionnel)
CONTENT_AUTHOR_ID=00000000-0000-0000-0000-000000000001

# Sentry (production uniquement — ne pas définir en dev pour garder Sentry inactif)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
