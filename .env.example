# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:64321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Supabase Management API (production) — nécessaires pour `npm run migrate` et `npm run supabase:config:push`
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_ID=

# Inscription (URL secrète)
SIGNUP_SECRET_TOKEN=

# Import de contenu (optionnel)
CONTENT_AUTHOR_ID=00000000-0000-0000-0000-000000000001

# SMTP (envoi d'emails — feedback visiteurs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sentry (production uniquement — ne pas définir en dev pour garder Sentry inactif)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
