    "babel-preset-react": "<6.3.0",
    "babel-preset-stage-0": "<6.3.0",
    "babel-register": "<6.3.0",
    "copy-webpack-plugin": "^2.1.3",
    "css-loader": "^0.23.0",
    "enzyme": "^2.3.0",
    "eslint": "^2.5.3",
    "eslint-config-airbnb": "^6.2.0",
    "eslint-plugin-import": "^1.10.2",
    "eslint-plugin-jsx-a11y": "^1.5.5",
