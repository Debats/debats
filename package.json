{
  "name": "debats",
  "version": "0.0.1",
  "description": "Débats.co",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run typecheck && NODE_ENV=production npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "migrate": "supabase link --project-ref $SUPABASE_PROJECT_ID && supabase db push",
    "import:content": "node --env-file=.env.local --import tsx scripts/import-content.ts",
    "import:content:production": "node --env-file=.env.production --import tsx scripts/import-content.ts",
    "supabase:config:push": "node --env-file=.env.production --import tsx scripts/push-prod-auth-config.ts"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.39.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.50.3",
    "bcrypt": "^6.0.0",
    "date-fns": "^4.1.0",
    "downshift": "^9.3.0",
    "effect": "^3.16.12",
    "next": "^16.1.7",
    "next-plausible": "^3.12.5",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^12.2.0",
    "nodemailer": "^8.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "supabase": "^2.76.8",
    "tsx": "^4.21.0",
    "typescript": "~5.2.2",
    "vitest": "^3.2.4"
  }
}
