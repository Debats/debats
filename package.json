  "description": "Front for Débats.co website",
  "author": "Jalil Arfaoui",
  "scripts": {
    "dev-local": "./node_modules/.bin/webpack-dev-server --config webpack/webpack.ds.config.js --inline --proxy --mockAPI --port 3000 --host 0.0.0.0 --progress --colors --hot --content-base build/dev",
    "dev-tiberefly": "./node_modules/.bin/webpack-dev-server --config webpack/webpack.ds.config.js --inline --proxy --tibereflyAPI --port 3000 --host 0.0.0.0 --progress --colors --hot --content-base build/dev",
    "dev-dev": "./node_modules/.bin/webpack-dev-server --config webpack/webpack.ds.config.js --inline --proxy --devAPI --port 3000 --host 0.0.0.0 --progress --colors --hot --content-base build/dev",
