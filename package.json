    "browser-sync-dev": "browser-sync start --server build/dev",
    "build-dev": "./node_modules/.bin/webpack --config webpack/webpack.config.js --development --progress --colors",
    "build-prod": "./node_modules/.bin/webpack --config webpack/webpack.config.js --production --progress --colors",
    "build-stats": "./node_modules/.bin/webpack --config webpack/webpack.config.js --production --json > stats.json",
    "copy-mocks": "node scripts/copy-mocks.js",
    "renderer": "node ./renderer/renderer.js",
    "clean": "./node_modules/.bin/rimraf ./build integration/main.css integration/static && echo --- Cleaned ---",
    "lint": "eslint src",
    "lint-fix": "eslint src --fix",
    "test": "karma start",
    "e2e-test": "./node_modules/.bin/nightwatch",
    "setup-test": "node selenium-download.js"
