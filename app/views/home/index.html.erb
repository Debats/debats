<% provide(:title, "Sujets") %>


<div class="subjects-index col-md-8" style="margin-bottom:20px">

<%= render @subjects %>
<%= will_paginate %>
</div>

<h1>Sujets <%= link_to "Créer un sujet", new_subject_path, class: "btn btn-primary" if  allowed_to(:add_subject) %></h1>


<div class="public-figures-index col-md-8" >

  <%= render @public_figures %>
</div>

<h1>Personnalités <%= link_to "Ajouter une personnalité", new_public_figure_path, class: "btn btn-primary" %></h1>


<div class="col-md-4">
<%= render 'layouts/last_statements' %>
</div>
